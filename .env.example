# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local AI
LOCAL_LLM_BASE_URL=http://127.0.0.1:8000
LOCAL_LLM_MODEL=caremind-chat
LOCAL_EMBEDDING_MODEL=caremind-embed
# Milvus vector DB configuration
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=caremind_chunks
MILVUS_DIM=128
# Optional credentials if your Milvus deployment requires them
MILVUS_USER=
MILVUS_PASSWORD=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
